      callbacks:
        paymentInitiationStatus:
          '{YOUR-SERVER-DOMAIN.com}':
            post:
              requestBody:
                content:
                  application/json:
                    schema:
                      $ref: '#/components/schemas/PaymentInitiationStatusCallback'
                required: true
              x-examples:
                - messageId: 333fb869-241a-4efc-b840-9518ac4538eb
                  messageType: ACH_TXN_STATUS
                  sendTimeStamp: '2020-03-11T19:50:41.789'
                  totalNbrOfTxns: 1
                  transactionData:
                    - paymentStatus: ACCEPTED
                      createDateTime: '2020-03-11T19:50:41.784'
                      crDrIndicator: CR
                      processingInfo:
                        statusCode: '0000'
                        statusText: No Error
                      reqExeDate: '2018-12-03'
                      txnAmountCcy: USD
                      txnAmount: 5.83
                      endToEndId: HLfffh0j9f
                      jpmcPmtRefId: b13405a8280741eab405a82807c1eaa0
                      jpmcPmtBatchId: SCXHUN0E
              responses:
                '200':
                  description: Success
      tags:
        - Payment Initiation - LV (ACH)
      responses:
        '200':
          description: |
            successful operation
            | Success Code      | Description                               |
            |---------------    |-------------------------------------------|
            |  PMT-C001         |  SUCCESS                   |
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/transactionResponseObject'
        '400':
          description: |
            | Error Code | Description |
            |------------|-------------|
            | PMT-E005   | EndToEndId field is required |
            | PMT-E006   | EndToEndId is not in correct format |
            | PMT-E007   | Please re-send request in valid format. These errors include: |
            |            | - Schema validation failed |
            |            | - Mandatory Fields Missing |
            |            | - Invalid Amount |
            |            | - Invalid Currency |
            |            | - Invalid Data |
            |            | - Requested Effective/Collection date must be in valid format: YYYY-MM-DD |
            |            | - Requested Effective/Collection Date cannot be outside of a valid calendar date: e.g. 2020-90-24 |
            |            | - Requested Effective/Collection Date cannot be in the past |
            |            | - Requested Effective/Collection Date cannot be 85 days in the future from the current day |
            |            | - API shall reject if any of the below characters are provided. Invalid characters: |
            |            |   - `\n`  : line feed |
            |            |   - `\u000A`: escaped unicode for line feed |
            |            |   - `\r`   : carriage return |
            |            |   - `\u000D` : escaped unicode for carriage return |
            | PMT-E010   | endToEndId must be unique |
            | PMT-E011   | instructedAmount or equivalentAmount is required with amount and currency fields |
            | PMT-E012   | amount field is required |
            |  PMT-E014     | Invalid field combination; aba + memberId                   |
            | GCA-023    | Please re-send request in valid format |
            | GCA-029    | The requested debit account was not found |
            |  GCA-041     | Invalid parameter combination: debtorAccount must NOT be provided with iban AND accountNumber                   |
            |  GCA-043    | Invalid parameter combination: When debtorAccount isprovided with iban, then debtorAgent must NOT be provided with abaNumber                  |
            |  GCA-045     | debtorAccount must be provided with iban or accountNumber                  |
            |  GCA-047     | When debtorAccount is provided with accountNumber, bic or aba is required. When debtorAccount is provided with iban, bic is required                   |
            |  GCA-049    | Invalid parameter combination: debtorAgent must NOT be provided with bic AND abaNumber                   |
            | GCA-051    | ACH Company id and Account combination was not found |
            | GCA-055    | ACH Company id was not provided |
            | GCA-056    | bic must be provided with accountNumber |
            |  GCA-057     | country is required in the debtorAgent                   |
            |  GCA-059     | serviceLevelCode is required                   |
            |  GCA-060     | serviceLevelCode value is invalid                   |
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/transactionResponseObject'
        '403':
          description: |
            | Error Code      | Description                               |
            |---------------  |-------------------------------------------|
            |  GCA-001       | Unauthorized Access                    |
            |  GCA-003       | Unauthorized Access                    |
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/transactionResponseObject'
        '503':
          description: |
            **Service Unavailable**

            | Error Code      | Description                               |
            |---------------  |-------------------------------------------|
            |  GCA-099       | System is Unavailable                         |
            |  GCA-030       | Access API Processing Error                   |

            In some situations a 503 status code is returned due to the API
            timing out, however the payment is successfully processed. J.P.
            Morgan recommends that you check the status of the transaction
            before retrying to submit the payment via API
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/transactionResponseObject'
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/transactionRequestObject'
        description: Initiate ACH Payments.
        required: true
      x-s2o-consumes: []
      x-s2o-produces: []
components:
  schemas:
    paymentTypeInformation:
      type: object
      required:
        - serviceLevelCode
      additionalProperties: false
      properties:
        serviceLevelCode:
          type: string
          description: Service Code - Payment Information Level
        localInstrument:
          type: object
          properties:
            code:
              type: string
            proprietary:
              type: string
          additionalProperties: false
        categoryPurpose:
          type: object
          additionalProperties: false
          properties:
            code:
              type: string
            proprietary:
              type: string
              description: "The code 'REVERSAL' can be used here to initiate a US ACH Reversal for eligible transactions. Eligibility requirements for initiating reversals are: \n A original transaction was already submitted via API with the same End to End ID of the reversal being requested \n • Original transaction is not in a status of PENDING, REJECTED, or RETURNED \n • Reversal must be the opposite transaction type of the original transaction \n • A reversal request has not already been submitted \n • requestedExecutionDate of the reversal must be within 5 banking days of the original payment \n • All information besides requestedExecutionDate in the reversal payment instruction must be the same as the original payment (opposite transaction type)"
        instructionproprietary:
          type: string
    processingInfo:
      type: array
      items:
        type: object
        properties:
          statusCode:
            type: string
          statusText:
            type: string
    transactionRequestObject:
      type: object
      description: |
        Carriage returns and line feeds are not permitted. Only the following Latin character set used in payment instructions,
        will ensure straight-through-processing. This character set is confirmed
        to be accepted across the majority of banks, markets, and clearing
        systems worldwide. Usage of additional characters may be supported in
        some instances but cannot be guaranteed through all systems involved in
        the payment lifecycle

          | Characters | Comments |
          |------------|-----------|
          | A to Z     | UPPERCASE and lowercase|
          | 0 to 9     |           |
          |  /         | Forward Oblique|
          |  -         | Hyphen |
          |  ?         | Question mark |
          |  :         | Colon |
          |  (         | Open bracket |
          |  )         | Close bracket |
          |  .         | Period |
          |  ,         | Comma |
          |  '         | Apostrophe |
          |  +         | Plus sign |
          |  Space     | Space character |
      required:
        - paymentMethod
        - requestedExecutionDate
        - paymentTypeInformation
        - debtor
        - debtorAccount
        - debtorAgent
        - creditTransferTransactionInformation
      properties:
        paymentMethod:
          type: string
          description: Method of payment
        paymentTypeInformation:
          $ref: '#/components/schemas/paymentTypeInformation'
        chargeBearer:
          type: string
        requestedExecutionDate:
          type: string
          description: Requested Execution Date of the Payment Instruction (e.g. Value Date) in ISO Date format of YYYY-MM-DD. Must be either the current date or within 85 days in the future (Eastern Timezone ET)
        debtor:
          $ref: '#/components/schemas/debtor'
        debtorAccount:
          $ref: '#/components/schemas/debtorAccount'
        debtorAgent:
          $ref: '#/components/schemas/debtorAgent'
        creditTransferTransactionInformation:
          $ref: '#/components/schemas/creditTransferTransactionInformation'
    transactionResponseObject:
      type: object
      properties:
        endToEndId:
          type: string
        jpmcPmtRefId:
          type: string
          description: JPMC issued unique Id for the payment
        jpmcPmtBatchId:
          type: string
          description: JPMC issued batch Id for the payment. This will provide more transparency about how your transactions are batched ahead of time
        sendTimeStamp:
          type: string
        messageType:
          type: string
        processingInfo:
          $ref: '#/components/schemas/processingInfo'
      required:
        - endToEndId
    PaymentInitiationStatusCallback:
      type: object
      required:
        - sendTimeStamp
        - messageId
        - messageType
        - totalNbrOfTxns
        - transactionData
      properties:
        sendTimeStamp:
          type: string
          format: date-time
          description: Date and time at which the callback message is sent. The date &amp; time are expressed in UTC timezone (without offset). Each re-try of the callback message will contain the same sendTimeStamp of the original callback message until J.P. Morgan receives an HTTP 200 OK for the callback message
        messageId:
          type: string
          description: Unique messageId for the callback message. Each re-try of the callback message will contain the same messageId of the original callback message until J.P. Morgan receives an HTTP 200 OK for the callback message
          maxLength: 50
        messageType:
          type: string
          description: The type of the message hardcoded to 'ACH_TXN_STATUS'.
          maxLength: 50
        totalNbrOfTxns:
          type: integer
          description: Total number of payments in the callback message. Each callback message will only contain either Credit or Debit payments.
        transactionData:
          type: array
          items:
            $ref: '#/components/schemas/transactionData'
    transactionData:
      type: object
      required:
        - paymentStatus
        - processingInfo
        - createDateTime
        - crDrIndicator
        - reqExeDate
        - txnAmountCcy
        - txnAmount
        - endToEndId
        - jpmcPmtRefId
      properties:
        paymentStatus:
          type: string
          description: 'Short descriptive status text of the payment. Possible values: ''ACCEPTED'', ''HOLD'', ''CLEARED'', ''COMPLETED'', ''REJECTED'', ''RETURNED''. If multiple state updates arrive API Channel at same time, the latest will be sent back to client. The obsolete ones will be discarded. Client is advised not to enforce strict step-by-step state transition validation.'
        processingInfo:
          required:
            - statusCode
            - statusText
          type: object
          properties:
            statusCode:
              type: string
            statusText:
              type: string
        createDateTime:
          type: string
          format: date-time
          description: 'Date &amp; Time at which J.P. Morgan receives the payment initiation request. Format : YYYY-MM-DDTHH:MM:SS.sss wth timezone difference'
        crDrIndicator:
          type: string
          description: To classify whether the payment request is a credit or debit. <br> CR = Credit<br> DR = Debit. Each callback message will only contain either Credit or Debit payments.
        reqExeDate:
          type: string
